+func (d *dnsResolver) lookupWithError() (*resolver.State, error) {
+	srv := d.lookupSRV()
+	addrs, err := d.lookupHostWithError()
+	if err != nil {
+		return nil, err
+	}
+	state := &resolver.State{
+		Addresses: append(addrs, srv...),
+	}
+	if !d.disableServiceConfig {
+		state.ServiceConfig = d.lookupTXT()
+	}
+	return state, nil
+}
