+#[inline]
+fn sign_extend(val: u64, nbytes: usize) -> i64 {
+    let shift = match 8usize.checked_sub(nbytes) {
+        Some(n) => n * 8,
+        None => panic_does_not_fit(8, nbytes),
+    };
+
+    if shift == 64 {
+        0
+    } else {
+        ((val << shift) as i64) >> shift
+    }
+}
