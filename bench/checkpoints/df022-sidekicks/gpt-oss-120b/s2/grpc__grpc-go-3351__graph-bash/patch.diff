diff --git c/balancer/grpclb/grpclb_remote_balancer.go i/balancer/grpclb/grpclb_remote_balancer.go
index e70ce75007..03a82eb40f 100644
--- c/balancer/grpclb/grpclb_remote_balancer.go
+++ i/balancer/grpclb/grpclb_remote_balancer.go
@@ -93,6 +93,23 @@ func (lb *lbBalancer) processServerList(l *lbpb.ServerList) {
 	lb.refreshSubConns(backendAddrs, false, lb.usePickFirst)
 }
 
+// processFallbackResponse causes the balancer to enter fallback mode using the
+// backend addresses from the resolver.
+func (lb *lbBalancer) processFallbackResponse() {
+	if grpclog.V(2) {
+		grpclog.Infof("lbBalancer: processing fallback response")
+	}
+	lb.mu.Lock()
+	defer lb.mu.Unlock()
+
+	// Treat the fallback response as a response from the remote balancer so the
+	// fallback timeout goroutine will not attempt to fall back again.
+	lb.serverListReceived = true
+
+	// Enter fallback.
+	lb.refreshSubConns(lb.resolvedBackendAddrs, true, lb.usePickFirst)
+}
+
 // refreshSubConns creates/removes SubConns with backendAddrs, and refreshes
 // balancer state and picker.
 //
@@ -277,6 +294,8 @@ func (ccw *remoteBalancerCCWrapper) readServerList(s *balanceLoadClientStream) e
 		}
 		if serverList := reply.GetServerList(); serverList != nil {
 			ccw.lb.processServerList(serverList)
+		} else if fallbackResponse := reply.GetFallbackResponse(); fallbackResponse != nil {
+			ccw.lb.processFallbackResponse()
 		}
 	}
 }
