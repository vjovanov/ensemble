diff --git c/include/simdjson/dom/base.h i/include/simdjson/dom/base.h
index b862277a21..a3814af5ba 100644
--- c/include/simdjson/dom/base.h
+++ i/include/simdjson/dom/base.h
@@ -35,6 +35,21 @@ class key_value_pair;
 class object;
 class parser;
 
+/** @private Return whether the given JSON Pointer has valid RFC 6901 escape syntax. */
+simdjson_inline bool json_pointer_is_valid(std::string_view json_pointer) noexcept {
+  if (json_pointer.empty()) { return true; }
+  if (json_pointer[0] != '/') { return false; }
+  for (size_t i = 0; i < json_pointer.size(); i++) {
+    if (json_pointer[i] == '~') {
+      i++;
+      if (i == json_pointer.size() || (json_pointer[i] != '0' && json_pointer[i] != '1')) {
+        return false;
+      }
+    }
+  }
+  return true;
+}
+
 #ifdef SIMDJSON_THREADS_ENABLED
 struct stage1_worker;
 #endif // SIMDJSON_THREADS_ENABLED
