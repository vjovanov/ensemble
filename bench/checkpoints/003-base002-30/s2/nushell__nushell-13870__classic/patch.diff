 const LINE_ENDING_PATTERN: &[char] = &['\r', '\n'];
 
+fn trim_end_newline(string: &mut String) {
+    if string.ends_with('\n') {
+        string.pop();
+        if string.ends_with('\r') {
+            string.pop();
+        }
+    }
+}
+
+// Collecting a byte stream as input to another command should not make a failed external
+// command abort the pipeline; non-zero exit codes are reported when the external stream itself is
+// the pipeline result.
+fn byte_stream_into_string_ignore_exit_code(stream: ByteStream) -> Result<String, ShellError> {
+    let span = stream.span();
+
+    if !stream.type_().is_string_coercible() {
+        return Err(ShellError::TypeMismatch {
+            err_message: "expected string, but got binary".into(),
+            span,
+        });
+    }
+
+    let trim = matches!(
+        stream.source(),
+        ByteStreamSource::File(_) | ByteStreamSource::Child(_)
+    );
+
+    let mut bytes = Vec::new();
+    if let Some(mut reader) = stream.reader() {
+        reader.read_to_end(&mut bytes).err_span(span)?;
+    }
+
+    let mut string = String::from_utf8(bytes).map_err(|err| ShellError::NonUtf8Custom {
+        span,
+        msg: err.to_string(),
+    })?;
+    if trim {
+        trim_end_newline(&mut string);
+    }
+    Ok(string)
+}
