diff --git c/include/simdjson/base.h i/include/simdjson/base.h
index a73b84bd08..96ae332a72 100644
--- c/include/simdjson/base.h
+++ i/include/simdjson/base.h
@@ -54,6 +54,20 @@ class tape_ref;
 struct value128;
 enum class tape_type;
 
+inline bool json_pointer_has_valid_syntax(std::string_view json_pointer) noexcept {
+  if (json_pointer.empty()) { return true; }
+  if (json_pointer[0] != '/') { return false; }
+  for (size_t i = 0; i < json_pointer.size(); i++) {
+    if (json_pointer[i] == '~') {
+      if (i + 1 >= json_pointer.size()) { return false; }
+      char escaped = json_pointer[i + 1];
+      if (escaped != '0' && escaped != '1') { return false; }
+      i++;
+    }
+  }
+  return true;
+}
+
 } // namespace internal
 } // namespace simdjson
 
