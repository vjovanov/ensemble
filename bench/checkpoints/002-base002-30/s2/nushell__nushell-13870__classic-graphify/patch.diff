+fn collect_input_string(input: PipelineData, config: &Config) -> Result<String, ShellError> {
+    match input {
+        PipelineData::ByteStream(stream, ..) => {
+            let span = stream.span();
+            if !stream.type_().is_string_coercible() {
+                return Err(ShellError::TypeMismatch {
+                    err_message: "expected string, but got binary".into(),
+                    span,
+                });
+            }
+
+            let lines = stream
+                .lines()
+                .map(|lines| lines.collect::<Result<Vec<_>, _>>())
+                .transpose()?
+                .unwrap_or_default();
+            Ok(lines.join("\n"))
+        }
+        input => input.collect_string("", config),
+    }
+}
