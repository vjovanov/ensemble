+++ i/lib/compress/zstd_compress.c
@@ -250,6 +250,29 @@ static ZSTD_paramSwitch_e ZSTD_resolveRowMatchFinderMode(ZSTD_paramSwitch_e mode
     return mode;
 }
 
+#define ZSTD_ROW_HASH_MAX_HASHLOG 28  /* 24 bits for the row hash + 4 bits for the smallest row size */
+
+static void ZSTD_capRowHashLog(ZSTD_compressionParameters* cParams,
+                               ZSTD_paramSwitch_e useRowMatchFinder)
+{
+    assert(useRowMatchFinder != ZSTD_ps_auto);
+    if (ZSTD_rowMatchFinderUsed(cParams->strategy, useRowMatchFinder)
+      && cParams->hashLog > ZSTD_ROW_HASH_MAX_HASHLOG) {
+        cParams->hashLog = ZSTD_ROW_HASH_MAX_HASHLOG;
+    }
+}
+
+static void ZSTD_capShortCacheLogs(ZSTD_compressionParameters* cParams)
+{
+    U32 const maxShortCacheLog = 32 - ZSTD_SHORT_CACHE_TAG_BITS;
+    if (cParams->hashLog > maxShortCacheLog) {
+        cParams->hashLog = maxShortCacheLog;
+    }
+    if (cParams->chainLog > maxShortCacheLog) {
+        cParams->chainLog = maxShortCacheLog;
+    }
+}
+
