+fn collect_string(input: PipelineData, config: &Config) -> Result<String, ShellError> {
+    match input {
+        PipelineData::ByteStream(stream, ..) if stream.type_().is_string_coercible() => stream
+            .lines()
+            .map(|lines| {
+                lines
+                    .collect::<Result<Vec<_>, _>>()
+                    .map(|lines| lines.join("\n"))
+            })
+            .unwrap_or_else(|| Ok(String::new())),
+        input => input.collect_string("", config),
+    }
