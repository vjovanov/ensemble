+fn collect_input_string(
+    input: PipelineData,
+    separator: &str,
+    config: &Config,
+) -> Result<String, ShellError> {
+    match input {
+        PipelineData::ByteStream(stream, ..) => {
+            let span = stream.span();
+            if stream.type_().is_string_coercible() {
+                let trim = matches!(
+                    stream.source(),
+                    ByteStreamSource::File(..) | ByteStreamSource::Child(..)
+                );
+                if let Some(mut reader) = stream.reader() {
+                    let mut bytes = Vec::new();
+                    reader.read_to_end(&mut bytes).err_span(span)?;
+                    let mut string =
+                        String::from_utf8(bytes).map_err(|err| ShellError::NonUtf8Custom {
+                            span,
+                            msg: err.to_string(),
+                        })?;
+                    if trim {
+                        trim_end_newline(&mut string);
+                    }
+                    Ok(string)
+                } else {
+                    Ok(String::new())
+                }
+            } else {
+                Err(ShellError::TypeMismatch {
+                    err_message: "expected string, but got binary".into(),
+                    span,
+                })
+            }
+        }
+        input => input.collect_string(separator, config),
+    }
+}
+
+fn trim_end_newline(string: &mut String) {
+    if string.ends_with('\n') {
+        string.pop();
+        if string.ends_with('\r') {
+            string.pop();
+        }
+    }
+}
