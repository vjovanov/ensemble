+    /// Collect all the bytes of the [`ByteStream`] into a [`Vec<u8>`], but don't fail for a
+    /// non-zero child process exit code.
+    ///
+    /// This is used by internal commands that consume stdout from an external command earlier in
+    /// the pipeline. In that position, the external command's exit code should not abort the
+    /// pipeline, but the child still has to be waited on.
+    pub fn into_bytes_ignore_exit_code(self) -> Result<Vec<u8>, ShellError> {
+        // todo!() ctrlc
+        match self.stream {
+            ByteStreamSource::Read(mut read) => {
+                let mut buf = Vec::new();
+                read.read_to_end(&mut buf).err_span(self.span)?;
+                Ok(buf)
+            }
+            ByteStreamSource::File(mut file) => {
+                let mut buf = Vec::new();
+                file.read_to_end(&mut buf).err_span(self.span)?;
+                Ok(buf)
+            }
+            ByteStreamSource::Child(child) => child.into_bytes_ignore_exit_code(),
+        }
+    }
