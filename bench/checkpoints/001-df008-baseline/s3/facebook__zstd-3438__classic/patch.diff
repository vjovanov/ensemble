+++ i/lib/compress/zstd_compress.c
@@ -231,6 +231,16 @@ static int ZSTD_rowMatchFinderUsed(const ZSTD_strategy strategy, const ZSTD_para
     return ZSTD_rowMatchFinderSupported(strategy) && (mode == ZSTD_ps_enable);
 }
 
+static void ZSTD_capRowMatchFinderHashLog(ZSTD_compressionParameters* cParams,
+                                          ZSTD_paramSwitch_e useRowMatchFinder)
+{
+    U32 const maxRowHashLog = 28; /* 24-bit row hash + 4-bit row size */
+    if (ZSTD_rowMatchFinderUsed(cParams->strategy, useRowMatchFinder)
+        && cParams->hashLog > maxRowHashLog) {
+        cParams->hashLog = maxRowHashLog;
+    }
+}
+
 /* Returns row matchfinder usage given an initial mode and cParams */
 static ZSTD_paramSwitch_e ZSTD_resolveRowMatchFinderMode(ZSTD_paramSwitch_e mode,
                                                          const ZSTD_compressionParameters* const cParams) {
@@ -303,6 +313,19 @@ static int ZSTD_CDictIndicesAreTagged(const ZSTD_compressionParameters* const cP
     return cParams->strategy == ZSTD_fast || cParams->strategy == ZSTD_dfast;
 }
 
+static void ZSTD_capShortCacheCParams(ZSTD_compressionParameters* cParams)
+{
+    if (ZSTD_CDictIndicesAreTagged(cParams)) {
+        U32 const maxShortCacheLog = 32 - ZSTD_SHORT_CACHE_TAG_BITS;
+        if (cParams->hashLog > maxShortCacheLog) {
+            cParams->hashLog = maxShortCacheLog;
+        }
+        if (cParams->chainLog > maxShortCacheLog) {
+            cParams->chainLog = maxShortCacheLog;
+        }
+    }
+}
