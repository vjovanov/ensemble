--- c/lib/compress/zstd_compress.c
+++ i/lib/compress/zstd_compress.c
@@ -303,6 +303,23 @@ static int ZSTD_CDictIndicesAreTagged(const ZSTD_compressionParameters* const cP
     return cParams->strategy == ZSTD_fast || cParams->strategy == ZSTD_dfast;
 }
 
+static void ZSTD_capCParamsForShortCache(ZSTD_compressionParameters* const cParams) {
+    if (ZSTD_CDictIndicesAreTagged(cParams)) {
+        U32 const maxShortCacheTableLog = 32 - ZSTD_SHORT_CACHE_TAG_BITS;
+        if (cParams->hashLog > maxShortCacheTableLog) cParams->hashLog = maxShortCacheTableLog;
+        if (cParams->chainLog > maxShortCacheTableLog) cParams->chainLog = maxShortCacheTableLog;
+    }
+}
+
+static void ZSTD_capCParamsForRowMatchFinder(ZSTD_compressionParameters* const cParams,
+                                             ZSTD_paramSwitch_e const useRowMatchFinder) {
+    if (ZSTD_rowMatchFinderUsed(cParams->strategy, useRowMatchFinder)) {
+        /* Row matchfinder hashes use 8 tag bits and at least 4 row bits. */
+        U32 const maxRowHashLog = 32 - ZSTD_SHORT_CACHE_TAG_BITS + 4;
+        if (cParams->hashLog > maxRowHashLog) cParams->hashLog = maxRowHashLog;
+    }
+}
+
